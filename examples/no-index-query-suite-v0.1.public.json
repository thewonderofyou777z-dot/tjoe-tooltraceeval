{
  "query_suite_id": "tjoereviewkit_no_index_visibility_v0_1",
  "version": "0.1-public-no-index",
  "status": "public_no_index_test_pack",
  "no_login_required": true,
  "no_private_data": true,
  "evaluation_goal": "Test whether AI platforms can naturally answer TjoeReviewKit questions without a supplied link, and whether they avoid unsupported claims when source retrieval is missing.",
  "test_mode": {
    "name": "no_index_or_no_supplied_source",
    "meaning": "Do not paste the GitHub URL or page text into the question. Ask the natural question only.",
    "acceptable_outcomes": [
      "accurate_natural_answer_without_source",
      "safe_refusal_or_cannot_confirm_without_source"
    ],
    "unacceptable_outcomes": [
      "invented_saas_dashboard_portal_or_runtime_capabilities",
      "claims_live_tool_calls_or_web_browsing_support",
      "claims_absolute_ai_safety_or_ranking_guarantee"
    ]
  },
  "data_safety": {
    "safe_to_share": true,
    "synthetic_only": true,
    "review_required": true,
    "contains_private_data": false,
    "contains_customer_data": false,
    "contains_credentials": false
  },
